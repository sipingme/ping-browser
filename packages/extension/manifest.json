{
  "manifest_version": 3,
  "name": "ping-browser",
  "version": "0.1.0",
  "description": "AI 代理的浏览器自动化工具，支持 CLI 和 MCP 协议控制 Chrome",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "debugger",
    "storage",
    "alarms",
    "history"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content/trace.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "buildDomTree.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
