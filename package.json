{
  "name": "ping-browser",
  "version": "0.1.0",
  "description": "Your browser is the API. CLI + MCP server for AI agents to control Chrome with your login state.",
  "type": "module",
  "bin": {
    "ping-browser": "./dist/cli.js",
    "ping-browser-mcp": "./dist/mcp.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "extension",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "turbo run build && pnpm build:release",
    "build:release": "tsup && pnpm build:extension",
    "build:extension": "rm -rf extension && cp -r packages/extension/dist extension",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules dist extension",
    "prepublishOnly": "echo 'Build already done'"
  },
  "keywords": [
    "browser",
    "automation",
    "ai",
    "agent",
    "chrome",
    "extension",
    "cli",
    "puppeteer",
    "playwright",
    "cdp",
    "mcp"
  ],
  "author": "Ping Si <sipingme@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sipingme/ping-browser.git"
  },
  "bugs": {
    "url": "https://github.com/sipingme/ping-browser/issues"
  },
  "homepage": "https://github.com/sipingme/ping-browser#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-node": "^2.1.1",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "eslint": "^9.23.0",
    "globals": "^16.0.0",
    "tsup": "^8.0.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.29.0"
  }
}